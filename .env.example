# ============================================================
# FinHouse — Environment Configuration
# Copy to .env and fill in your values
# ============================================================

# ── Stack deployment ────────────────────────────────────────
# This file is shared across all stacks. Pick which stack(s)
# to run on this host with start.sh:
#
#   ./start.sh system      — API, UI, Postgres, MinIO, Milvus, SearXNG
#   ./start.sh ollama      — Ollama LLM only
#   ./start.sh models      — BGE-M3 embed + rerank only
#   ./start.sh pipeline    — NiFi + Spark + ClickHouse (OLAP ingest)
#   ./start.sh all         — all four (single-host deployment)
#
# Default recommended topology (2 servers):
#   <ip1>: system + models           (app + DB + Milvus + embed/rerank GPU)
#   <ip2>: ollama + pipeline         (LLM GPU + OLAP data pipeline)
#
# For split deployments, sync this code to each server, edit the
# host URLs below to point at each server's public IP, then run
# the appropriate ./start.sh on each host.
# ────────────────────────────────────────────────────────────

# ── Server identifiers (used by docs and switch scripts) ────
# These are purely informational — they don't affect runtime.
# Fill in your actual IPs / hostnames here so the switch scripts
# and REMOTE.md guides know where to point components.
IP1=127.0.0.1
IP2=127.0.0.1

# SSH credentials for remote administration (NOT used by the app).
# Used by scripts/ssh-to.sh helper and docs examples.
SSH_USER=your_ssh_user
SSH_PASSWORD=your_ssh_password

# ── PostgreSQL ──────────────────────────────────────────────
POSTGRES_USER=finhouse
POSTGRES_PASSWORD=changeme_pg_secret
POSTGRES_DB=finhouse

# ── MinIO ───────────────────────────────────────────────────
MINIO_ROOT_USER=finhouse
MINIO_ROOT_PASSWORD=changeme_minio_secret
MINIO_BUCKET=finhouse-files

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=changeme_jwt_secret_at_least_32_chars
JWT_ACCESS_EXPIRE_MINUTES=30
JWT_REFRESH_EXPIRE_DAYS=7

# ── Ollama ──────────────────────────────────────────────────
# Local (default): http://finhouse-ollama:11434
# Remote Ollama on another server: http://your-server.example.com:11434
# Point to a public/reachable URL when you split deployment.
OLLAMA_HOST=http://finhouse-ollama:11434
DEFAULT_MODEL=qwen2.5:14b

# ── Embedding / Reranker ────────────────────────────────────
# Local services (primary)
EMBED_HOST=http://finhouse-bge-m3:8081
RERANK_HOST=http://finhouse-reranker:8082

# Mode selector — controls which backend handles each call.
#   local   → call the local/remote Docker service only (EMBED_HOST)
#   backup  → call the managed API only (EMBED_API_URL), skip local entirely
#   auto    → try local first; sticky-switch to API after LOCAL_FAILURE_THRESHOLD failures
EMBED_MODE=local
RERANK_MODE=local

# Managed API credentials — used when MODE is "backup" or "auto".
# OpenAI-compatible endpoints (FPT Cloud, OpenAI, Together, etc.)
# Leave blank if MODE=local only.
EMBED_API_URL=
EMBED_API_KEY=
EMBED_API_MODEL=Vietnamese_Embedding
EMBED_API_DIMENSIONS=1024

RERANK_API_URL=
RERANK_API_KEY=
RERANK_API_MODEL=bge-reranker-v2-m3

# In "auto" mode: how many consecutive local failures before switching to API
LOCAL_FAILURE_THRESHOLD=2

# ── Milvus ──────────────────────────────────────────────────
MILVUS_HOST=finhouse-milvus
MILVUS_PORT=19530

# ── SearXNG (Web Search) ───────────────────────────────────
SEARXNG_HOST=http://finhouse-searxng:8080

# ── Cleanup Cron ────────────────────────────────────────────
CLEANUP_INTERVAL_MINUTES=60

# ── Data Folder (auto-scanned on startup) ───────────────────
# Place files in ./data — they are mounted read-only into the API container.
# Supported: pdf, md, txt, docx → ingested for RAG
# Unsupported formats → marked as 'failed'
DATA_DIR=/app/data

# ── Environment Mode ────────────────────────────────────────
# dev: warns if default placeholder secrets are used (above)
# prod: refuses to start if placeholder secrets are still set
ENV=dev

# ── CORS ────────────────────────────────────────────────────
# Comma-separated list of allowed origins. DO NOT use "*" if you want
# cookies/credentials to work (browsers block that combination).
# For local dev, the Streamlit UI runs on http://localhost:8501.
CORS_ALLOW_ORIGINS=http://localhost:8501,http://127.0.0.1:8501

# ════════════════════════════════════════════════════════════
# PIPELINE stack — OLAP data ingestion (NiFi + Spark + ClickHouse)
# ════════════════════════════════════════════════════════════

# ── ClickHouse (OLAP database) ──────────────────────────────
# Empty CLICKHOUSE_HOST → database_query tool is DISABLED in the agent.
# Local (pipeline on same host as API):
#   CLICKHOUSE_HOST=finhouse-clickhouse
# Remote (pipeline on ip2, API on ip1):
#   CLICKHOUSE_HOST=<ip2>
CLICKHOUSE_HOST=
CLICKHOUSE_PORT=8123
CLICKHOUSE_USER=finhouse
CLICKHOUSE_PASSWORD=changeme_clickhouse
CLICKHOUSE_DB=olap

# Safety bounds for the database_query tool
DATABASE_QUERY_MAX_ROWS=1000
DATABASE_QUERY_MAX_SQL_LEN=4000

# ── NiFi ────────────────────────────────────────────────────
# Admin user for NiFi UI at http://<host>:8090/nifi
# Password must be at least 12 characters (NiFi requirement).
NIFI_USER=admin
NIFI_PASSWORD=changeme_nifi_12chars_min
# If accessing NiFi from a remote machine, set this to "<host>:8090"
# so NiFi's proxy-host check allows the request.
NIFI_PROXY_HOST=localhost:8090

# ── Airflow ─────────────────────────────────────────────────
# Orchestrates Spark ingest jobs triggered by NiFi.
# UI + REST API at http://<host>:8091
AIRFLOW_USER=admin
AIRFLOW_PASSWORD=changeme_airflow_12c_min
AIRFLOW_DB_PASSWORD=changeme_airflow_db_pw
# Fernet key for at-rest credential encryption. Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# Leave empty to let Airflow auto-generate (fine for dev, lose secrets on wipe).
AIRFLOW_FERNET_KEY=
# UID that owns the ./pipeline/airflow/ directory tree on the host.
# Must match your host user so logs/dags are writable.
AIRFLOW_UID=50000

# ── Spark ───────────────────────────────────────────────────
# Resource limits for the Spark worker. Bump if ingesting large files.
SPARK_WORKER_MEMORY=2G
SPARK_WORKER_CORES=2
